# .env.example

# Required
GOOGLE_API_KEY=AIzaSy...

# Storage
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
DATABASE_URL=sqlite:///./dark_guard.db

# MCP Server
MCP_HOST=localhost
MCP_PORT=8765

# Model Settings
# Replaces Claude Sonnet 4 (Reasoning/Routing)
ORCHESTRATOR_MODEL=gemini-3.1-pro

# Replaces Claude Sonnet 4 (General NLP/Tool Use)
NLP_AGENT_MODEL=gemini-3.1-pro

# Replaces Claude Opus 4.5 (High-Fidelity Vision/Reasoning)
# Gemini 3.1 Pro is natively multimodal and outperforms older Opus models in vision.
VISUAL_AGENT_MODEL=gemini-3.1-pro

# Replaces Claude Sonnet 4 (Guardrails/Safety)
# Flash is recommended here for lower latency, but you can use 'gemini-3.1-pro' for maximum strictness.
PREVENTION_MODEL=gemini-3.1-flash

# Thresholds
HIGH_CONFIDENCE_THRESHOLD=0.80
MEDIUM_CONFIDENCE_THRESHOLD=0.55
LOW_CONFIDENCE_THRESHOLD=0.35

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
